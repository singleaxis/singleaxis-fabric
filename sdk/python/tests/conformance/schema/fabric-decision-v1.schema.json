{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/singleaxis/singleaxis-fabric/schema/fabric-decision-v1.schema.json",
  "title": "Fabric decision span + span-event contract (SCHEMA_VERSION 1.0)",
  "description": "Formal contract for the fabric.* / gen_ai.* span attributes and span events emitted by the Python SDK at SCHEMA_VERSION 1.0. Hash fields are 64-char lowercase hex SHA-256. Sequence attributes are emitted as OTel array attributes. This document is the source the future TypeScript SDK is validated against; the golden fixtures in ../goldens are the concrete instances.",
  "type": "object",
  "required": ["decision_span", "events", "child_spans"],
  "additionalProperties": false,
  "properties": {
    "execution_span": {
      "type": "object",
      "description": "Attributes on the OPTIONAL fabric.execution span (kind=INTERNAL). An execution is an outer correlation + lifecycle span; emit-only, not required. Scenarios without an execution omit this key entirely.",
      "required": [
        "fabric.schema_version",
        "fabric.tenant_id",
        "fabric.agent_id",
        "fabric.profile",
        "fabric.execution_id"
      ],
      "additionalProperties": false,
      "properties": {
        "fabric.schema_version": { "const": "1.0" },
        "fabric.tenant_id": { "type": "string" },
        "fabric.agent_id": { "type": "string" },
        "fabric.profile": { "type": "string" },
        "fabric.execution_id": { "type": "string" },
        "fabric.workflow_id": { "type": "string" },
        "fabric.execution.status": { "enum": ["completed", "failed"] },
        "fabric.execution.attempt_id": { "type": "string" },
        "fabric.execution.attempt": { "type": "integer", "minimum": 1 },
        "fabric.execution.retry.reason": { "type": "string" },
        "fabric.execution.retry.previous_attempt_id": { "type": "string" }
      }
    },
    "decision_span": {
      "type": "object",
      "description": "Attributes on the fabric.decision span (kind=INTERNAL).",
      "required": [
        "fabric.schema_version",
        "fabric.tenant_id",
        "fabric.agent_id",
        "fabric.profile",
        "fabric.session_id",
        "fabric.request_id"
      ],
      "additionalProperties": true,
      "properties": {
        "fabric.schema_version": { "const": "1.0" },
        "fabric.decision_id": { "type": "string" },
        "fabric.tenant_id": { "type": "string" },
        "fabric.agent_id": { "type": "string" },
        "fabric.profile": { "type": "string" },
        "fabric.workflow_id": { "type": "string" },
        "fabric.execution_id": { "type": "string" },
        "fabric.execution.attempt_id": { "type": "string" },
        "fabric.execution.attempt": { "type": "integer", "minimum": 1 },
        "fabric.execution.retry.reason": { "type": "string" },
        "fabric.execution.retry.previous_attempt_id": { "type": "string" },
        "fabric.session_id": { "type": "string" },
        "fabric.request_id": { "type": "string" },
        "fabric.user_id": { "type": "string" },
        "fabric.blocked": { "type": "boolean" },
        "fabric.blocked.policies": { "type": "array", "items": { "type": "string" } },
        "fabric.escalated": { "type": "boolean" },
        "fabric.escalation.reason": { "type": "string" },
        "fabric.escalation.rubric_id": { "type": "string" },
        "fabric.escalation.mode": { "enum": ["sync", "async", "deferred"] },
        "fabric.escalation.triggering_score": { "type": "number" },
        "fabric.retrieval_count": { "type": "integer", "minimum": 0 },
        "fabric.retrieval_sources": { "type": "array", "items": { "type": "string" } },
        "fabric.memory_write_count": { "type": "integer", "minimum": 0 },
        "fabric.memory_read_count": { "type": "integer", "minimum": 0 },
        "fabric.memory_erase_count": { "type": "integer", "minimum": 0 },
        "fabric.memory_kinds": { "type": "array", "items": { "type": "string" } },
        "fabric.side_effect_count": { "type": "integer", "minimum": 0 },
        "fabric.side_effect_types": { "type": "array", "items": { "type": "string" } },
        "fabric.side_effect_systems": { "type": "array", "items": { "type": "string" } },
        "fabric.checkpoint_count": { "type": "integer", "minimum": 0 },
        "fabric.eval_count": { "type": "integer", "minimum": 0 },
        "fabric.eval_rubrics": { "type": "array", "items": { "type": "string" } },
        "fabric.judge_queued_count": { "type": "integer", "minimum": 0 },
        "fabric.judge_rubrics": { "type": "array", "items": { "type": "string" } },
        "fabric.policy_evaluation_count": { "type": "integer", "minimum": 0 },
        "fabric.policy_engines": { "type": "array", "items": { "type": "string" } },
        "fabric.tool_authorization_count": { "type": "integer", "minimum": 0 }
      }
    },
    "events": {
      "type": "object",
      "description": "Allowed span events by name, with their attribute contracts.",
      "additionalProperties": false,
      "properties": {
        "fabric.guardrail": {
          "type": "object",
          "required": [
            "fabric.schema_version",
            "fabric.guardrail.phase",
            "fabric.guardrail.latency_ms",
            "fabric.guardrail.blocked"
          ],
          "additionalProperties": false,
          "properties": {
            "fabric.schema_version": { "const": "1.0" },
            "fabric.guardrail.phase": { "enum": ["input", "output_stream", "output_final"] },
            "fabric.guardrail.latency_ms": { "type": "number", "minimum": 0 },
            "fabric.guardrail.blocked": { "type": "boolean" },
            "fabric.guardrail.entities": { "type": "array", "items": { "type": "string" } },
            "fabric.guardrail.policies": { "type": "array", "items": { "type": "string" } },
            "fabric.guardrail.content_ref": { "type": "string" }
          }
        },
        "fabric.escalation": {
          "type": "object",
          "required": [
            "fabric.schema_version",
            "fabric.escalation.reason",
            "fabric.escalation.mode"
          ],
          "additionalProperties": false,
          "properties": {
            "fabric.schema_version": { "const": "1.0" },
            "fabric.escalation.reason": { "type": "string" },
            "fabric.escalation.mode": { "enum": ["sync", "async", "deferred"] },
            "fabric.escalation.rubric_id": { "type": "string" },
            "fabric.escalation.triggering_score": { "type": "number" }
          }
        },
        "fabric.retrieval": {
          "type": "object",
          "required": [
            "fabric.schema_version",
            "fabric.retrieval.source",
            "fabric.retrieval.query_hash",
            "fabric.retrieval.result_count"
          ],
          "additionalProperties": false,
          "properties": {
            "fabric.schema_version": { "const": "1.0" },
            "fabric.retrieval.source": {
              "enum": ["rag", "kg", "sql", "tool", "memory", "document", "hybrid"]
            },
            "fabric.retrieval.query_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "fabric.retrieval.result_count": { "type": "integer", "minimum": 0 },
            "fabric.retrieval.result_hashes": { "type": "array", "items": { "type": "string" } },
            "fabric.retrieval.source_document_ids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "fabric.retrieval.latency_ms": { "type": "integer", "minimum": 0 }
          }
        },
        "fabric.memory": {
          "type": "object",
          "required": [
            "fabric.schema_version",
            "fabric.memory.direction",
            "fabric.memory.kind"
          ],
          "additionalProperties": false,
          "properties": {
            "fabric.schema_version": { "const": "1.0" },
            "fabric.memory.direction": { "enum": ["read", "write", "erase"] },
            "fabric.memory.kind": { "enum": ["episodic", "semantic", "scratch"] },
            "fabric.memory.content_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "fabric.memory.key": { "type": "string" },
            "fabric.memory.tags": { "type": "array", "items": { "type": "string" } },
            "fabric.memory.ttl_seconds": { "type": "integer", "minimum": 0 },
            "fabric.memory.source": { "type": "string" },
            "fabric.memory.invalidates": { "type": "string" },
            "fabric.memory.tenant_scope": { "type": "boolean" }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "fabric.memory.direction": { "enum": ["read", "write"] }
                }
              },
              "then": { "required": ["fabric.memory.content_hash"] }
            }
          ]
        },
        "fabric.side_effect": {
          "type": "object",
          "required": [
            "fabric.schema_version",
            "fabric.side_effect.type",
            "fabric.side_effect.target_system",
            "fabric.side_effect.operation",
            "fabric.side_effect.approval_required",
            "fabric.side_effect.committed",
            "fabric.side_effect.rollback_supported",
            "fabric.side_effect.replay_behavior"
          ],
          "additionalProperties": false,
          "properties": {
            "fabric.schema_version": { "const": "1.0" },
            "fabric.side_effect.type": {
              "enum": [
                "external_write",
                "api_mutation",
                "database_write",
                "file_write",
                "email_send",
                "ticket_create",
                "payment",
                "notification",
                "other"
              ]
            },
            "fabric.side_effect.target_system": { "type": "string" },
            "fabric.side_effect.operation": { "type": "string" },
            "fabric.side_effect.approval_required": { "type": "boolean" },
            "fabric.side_effect.committed": { "type": "boolean" },
            "fabric.side_effect.rollback_supported": { "type": "boolean" },
            "fabric.side_effect.replay_behavior": {
              "enum": ["replay", "suppress", "mock", "manual"]
            },
            "fabric.side_effect.side_effect_id": { "type": "string" },
            "fabric.side_effect.request_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "fabric.side_effect.result_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "fabric.side_effect.idempotency_key": { "type": "string" },
            "fabric.side_effect.parent_tool_call_id": { "type": "string" }
          }
        },
        "fabric.checkpoint": {
          "type": "object",
          "required": [
            "fabric.schema_version",
            "fabric.checkpoint.checkpoint_id",
            "fabric.checkpoint.step_name"
          ],
          "additionalProperties": false,
          "properties": {
            "fabric.schema_version": { "const": "1.0" },
            "fabric.checkpoint.checkpoint_id": { "type": "string" },
            "fabric.checkpoint.step_name": { "type": "string" },
            "fabric.checkpoint.state_hash": { "type": "string" }
          }
        },
        "fabric.eval": {
          "type": "object",
          "required": [
            "fabric.schema_version",
            "fabric.eval.eval_id",
            "fabric.eval.rubric_id",
            "fabric.eval.score",
            "fabric.eval.dimension",
            "fabric.eval.evaluator_name"
          ],
          "additionalProperties": false,
          "properties": {
            "fabric.schema_version": { "const": "1.0" },
            "fabric.eval.eval_id": { "type": "string" },
            "fabric.eval.rubric_id": { "type": "string" },
            "fabric.eval.score": { "type": "number", "minimum": 0, "maximum": 1 },
            "fabric.eval.dimension": { "type": "string" },
            "fabric.eval.evaluator_name": { "type": "string" },
            "fabric.eval.evaluator_version": { "type": "string" },
            "fabric.eval.confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "fabric.eval.payload_ref": { "type": "string" }
          }
        },
        "fabric.judge.queued": {
          "type": "object",
          "required": [
            "fabric.schema_version",
            "fabric.judge.request_id",
            "fabric.judge.rubric_id",
            "fabric.judge.dimensions"
          ],
          "additionalProperties": false,
          "properties": {
            "fabric.schema_version": { "const": "1.0" },
            "fabric.judge.request_id": { "type": "string" },
            "fabric.judge.rubric_id": { "type": "string" },
            "fabric.judge.dimensions": { "type": "array", "items": { "type": "string" } },
            "fabric.judge.payload_ref": { "type": "string" }
          }
        },
        "fabric.policy.evaluation": {
          "type": "object",
          "required": [
            "fabric.schema_version",
            "fabric.policy.evaluation_id",
            "fabric.policy.engine",
            "fabric.policy.policy_id",
            "fabric.policy.decision",
            "fabric.policy.input_hash",
            "fabric.policy.latency_ms"
          ],
          "additionalProperties": false,
          "properties": {
            "fabric.schema_version": { "const": "1.0" },
            "fabric.policy.evaluation_id": { "type": "string" },
            "fabric.policy.engine": { "type": "string" },
            "fabric.policy.policy_id": { "type": "string" },
            "fabric.policy.decision": {
              "enum": ["allow", "deny", "warn", "escalate", "redact"]
            },
            "fabric.policy.input_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "fabric.policy.latency_ms": { "type": "number", "minimum": 0 },
            "fabric.policy.policy_version": { "type": "string" },
            "fabric.policy.reason": { "type": "string" },
            "fabric.policy.evidence_ref": { "type": "string" },
            "fabric.policy.bundle_signature": { "type": "string" },
            "fabric.policy.input_content_ref": { "type": "string" }
          }
        },
        "fabric.tool.authorization": {
          "type": "object",
          "required": [
            "fabric.schema_version",
            "fabric.tool.name",
            "fabric.tool.authorization.decision"
          ],
          "additionalProperties": false,
          "properties": {
            "fabric.schema_version": { "const": "1.0" },
            "fabric.tool.name": { "type": "string" },
            "fabric.tool.authorization.decision": { "enum": ["allow", "deny"] },
            "fabric.tool.authorization.reason": { "type": "string" },
            "fabric.tool.arguments_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
          }
        }
      }
    },
    "child_spans": {
      "type": "object",
      "description": "Child spans opened under fabric.decision.",
      "additionalProperties": false,
      "properties": {
        "fabric.llm_call": {
          "type": "object",
          "description": "kind=CLIENT. Mirrors gen_ai.* into fabric.llm.*.",
          "required": ["gen_ai.system", "gen_ai.request.model"],
          "additionalProperties": false,
          "properties": {
            "gen_ai.system": { "type": "string" },
            "gen_ai.request.model": { "type": "string" },
            "gen_ai.request.temperature": { "type": "number" },
            "gen_ai.request.top_p": { "type": "number" },
            "gen_ai.request.max_tokens": { "type": "integer" },
            "gen_ai.response.model": { "type": "string" },
            "gen_ai.response.finish_reasons": { "type": "array", "items": { "type": "string" } },
            "gen_ai.usage.input_tokens": { "type": "integer", "minimum": 0 },
            "gen_ai.usage.output_tokens": { "type": "integer", "minimum": 0 },
            "fabric.llm.system": { "type": "string" },
            "fabric.llm.request.model": { "type": "string" },
            "fabric.llm.request.temperature": { "type": "number" },
            "fabric.llm.request.top_p": { "type": "number" },
            "fabric.llm.request.max_tokens": { "type": "integer" },
            "fabric.llm.response.model": { "type": "string" },
            "fabric.llm.response.finish_reasons": {
              "type": "array",
              "items": { "type": "string" }
            },
            "fabric.llm.usage.input_tokens": { "type": "integer", "minimum": 0 },
            "fabric.llm.usage.output_tokens": { "type": "integer", "minimum": 0 },
            "fabric.step.type": { "type": "string" },
            "fabric.step.id": { "type": "string" },
            "fabric.step.attempt_id": { "type": "string" },
            "fabric.step.attempt": { "type": "integer", "minimum": 1 },
            "fabric.step.retry.reason": { "type": "string" },
            "fabric.step.retry.previous_attempt_id": { "type": "string" }
          }
        },
        "fabric.tool_call": {
          "type": "object",
          "description": "kind=INTERNAL. Mirrors gen_ai.tool.* into fabric.tool.*.",
          "required": ["gen_ai.tool.name", "fabric.tool.name"],
          "additionalProperties": false,
          "properties": {
            "gen_ai.tool.name": { "type": "string" },
            "gen_ai.tool.call.id": { "type": "string" },
            "fabric.tool.name": { "type": "string" },
            "fabric.tool.call.id": { "type": "string" },
            "fabric.tool.kind": { "type": "string" },
            "fabric.tool.result_count": { "type": "integer", "minimum": 0 },
            "fabric.tool.arguments_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "fabric.tool.result_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "fabric.tool.error": { "type": "boolean" },
            "fabric.tool.error_category": { "type": "string" },
            "fabric.step.type": { "type": "string" },
            "fabric.step.id": { "type": "string" },
            "fabric.step.attempt_id": { "type": "string" },
            "fabric.step.attempt": { "type": "integer", "minimum": 1 },
            "fabric.step.retry.reason": { "type": "string" },
            "fabric.step.retry.previous_attempt_id": { "type": "string" }
          }
        }
      }
    }
  }
}
