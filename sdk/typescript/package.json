{
  "name": "@singleaxis/fabric",
  "version": "0.2.0",
  "description": "TypeScript SDK for SingleAxis Fabric — OpenTelemetry-native capture core emitting the fabric.*/gen_ai.* span contract for AI agents.",
  "license": "Apache-2.0",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/singleaxis/singleaxis-fabric.git",
    "directory": "sdk/typescript"
  },
  "homepage": "https://github.com/singleaxis/singleaxis-fabric/tree/main/sdk/typescript",
  "bugs": {
    "url": "https://github.com/singleaxis/singleaxis-fabric/issues"
  },
  "keywords": [
    "opentelemetry",
    "observability",
    "ai-agents",
    "gen_ai",
    "tracing",
    "governance"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/sdk-trace-node": "1.30.1"
  },
  "peerDependencies": {
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/exporter-trace-otlp-http": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@opentelemetry/context-async-hooks": "1.30.1",
    "@types/node": "22.18.0",
    "@typescript-eslint/eslint-plugin": "8.20.0",
    "@typescript-eslint/parser": "8.20.0",
    "eslint": "9.39.4",
    "prettier": "3.4.2",
    "tsup": "8.5.1",
    "typescript": "5.7.3",
    "vitest": "4.1.0"
  }
}
